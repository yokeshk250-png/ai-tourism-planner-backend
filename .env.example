# ─────────────────────────────────────────
# Groq API (Primary LLM) — FREE 14,400 req/day
# Get key (no credit card): https://console.groq.com/keys
# Models: llama-3.3-70b-versatile | llama3-70b-8192 | mixtral-8x7b-32768
# ─────────────────────────────────────────
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─────────────────────────────────────────
# Places APIs
# ─────────────────────────────────────────
FOURSQUARE_API_KEY=your_foursquare_api_key_here
GEOAPAFY_API_KEY=your_geoapify_api_key_here
OPENTRIPMAP_API_KEY=your_opentripmap_api_key_here

# ─────────────────────────────────────────
# Weather
# ─────────────────────────────────────────
OPENWEATHER_API_KEY=your_openweather_api_key_here

# ─────────────────────────────────────────
# Firebase
# ─────────────────────────────────────────
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json
FIREBASE_PROJECT_ID=your_firebase_project_id

# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
APP_ENV=development
DEBUG=True
